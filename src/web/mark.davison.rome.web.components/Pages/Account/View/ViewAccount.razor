@attribute [Route(Routes.Account)]

@inherits BaseView<ViewAccountViewModel, Guid>

<MudPaper Class="ma-10">
    @if (ViewModel.Loading)
    {
        <MudProgressCircular Size="Size.Large" Class="ma-auto" Indeterminate />
    }
    else
    {
        <MudStack Row="true">
            <MudText data-testid="@DataTestIds.ViewAccountTitle" Typo="Typo.h4">@ViewModel.Title</MudText>
            <MudTooltip Text="Add">@*What? Transaction where this defaults to source/dest????*@
                <MudIconButton Disabled Icon="@Icons.Material.Filled.AddCircle" Variant="Variant.Filled" Color="Color.Primary" Style="min-width: 60px;" />
            </MudTooltip>
        </MudStack>
    }
    </MudPaper>